{
  "ConnectionStrings": {
    "Default": "Data Source=transactions.db"
  },
  "Api": {
    "BaseUrl": "https://example-gateway.local/transactions",
    "UseMockFeed": true
  },
  "Feed": {
    "Path": "mock-data.json"
  },
  "CardHash": {
    "Enabled": true
  },
  "Ingest": {
    "FinalizeOlderThan24Hours": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
